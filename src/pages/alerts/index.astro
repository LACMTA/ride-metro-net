---
import Layout from "../../layouts/Layout.astro";
import Column from "../../components/Column";
import AlertIcon from "../../components/AlertIcon";
import RailIcon from "../../components/RailIcon";
import { Card, CardBody, CardHeader } from "../../components/Card";
import DataInjector from "../../components/DataInjector.astro";
import getAllRailBuswayRoutes from "../../lib/getAllRailBuswayRoutes";
import LineAlertStatusList from "../../components/LineAlertStatusList";

export const prerender = true;

const routes = await getAllRailBuswayRoutes();
---

<DataInjector data={routes} id="data-routes" />
<script>
  import { getData } from "../../lib/getData";
  import type { RouteWithInfo } from "../../lib/getRouteById";
  import watchAlerts from "../../lib/watchAlerts";

  const routes = getData("data-routes") as RouteWithInfo[];

  // Rail lines (lametro-rail) and busway lines (lametro) use different Swiftly
  // agency keys — pass both as separate queries so watchAlerts fetches them
  // concurrently and merges them into the shared alerts atom.
  const railRouteIds = routes
    .filter((r) => r.swiftlyAgencyId === "lametro-rail")
    .map((r) => r.routeId);
  const buswayRouteIds = routes
    .filter((r) => r.swiftlyAgencyId === "lametro")
    .map((r) => r.routeId);

  watchAlerts([
    { stopIds: [], routeIds: railRouteIds, agency: "lametro-rail" },
    { stopIds: [], routeIds: buswayRouteIds, agency: "lametro" },
  ]);
</script>

<Layout title="Alerts">
  <main>
    <Column>
      <div class="mt-6 mb-4">
        <div class="flex items-center gap-3">
          <AlertIcon className="text-yellow h-8 shrink-0" />
          <h1 class="text-4xl font-bold">Alerts</h1>
        </div>
        <p class="mt-4">
          Search for current status information, planned service outages, route
          maps and schedules below:
        </p>
      </div>
    </Column>
  </main>
  <div class="mt-6 bg-gray-200 py-6">
    <Column>
      <Card>
        <CardHeader
          ><RailIcon className="inline-block h-10" /> Rail & Busway</CardHeader
        >
        <CardBody margin={false}>
          <LineAlertStatusList routes={routes} client:load />
        </CardBody>
      </Card>
    </Column>
  </div>
</Layout>
