---
import Layout from "../../layouts/Layout.astro";
import Column from "../../components/Column";
import AlertIcon from "../../components/AlertIcon";
import RailIcon from "../../components/RailIcon";
import { Card, CardBody, CardHeader } from "../../components/Card";
import getAllRailBuswayRoutes from "../../lib/getAllRailBuswayRoutes";
import getAllBusRoutes from "../../lib/getAllBusRoutes";
import LineAlertStatusList from "../../components/LineAlertStatusList";
import BusIcon from "../../components/BusIcon";
import RouteBadge from "../../components/RouteBadge";

export const prerender = true;

const routes = await getAllRailBuswayRoutes();
const busRoutes = await getAllBusRoutes();
---

<script>
  import watchAlertStatus from "../../lib/watchAlertStatus";

  watchAlertStatus();
</script>

<Layout title="Alerts">
  <main>
    <Column>
      <div class="mt-6 mb-4">
        <div class="flex items-center gap-3">
          <AlertIcon className="text-yellow h-8 shrink-0" />
          <h1 class="text-4xl font-bold">Alerts</h1>
        </div>
        <p class="mt-4">
          Search for current status information, planned service outages, route
          maps and schedules below:
        </p>
      </div>
    </Column>
  </main>
  <div class="mt-6 bg-gray-200 py-6">
    <Column>
      <Card>
        <CardHeader
          ><RailIcon className="inline-block h-10" /> Rail & Busway</CardHeader
        >
        <CardBody margin={false}>
          <LineAlertStatusList routes={routes} client:load />
        </CardBody>
      </Card>
      <Card>
        <CardHeader><BusIcon className="inline-block h-10" /> Bus</CardHeader>
        <CardBody>
          <div class="flex-wrap">
            {
              busRoutes.map((route) => (
                <RouteBadge
                  routeId={route.routeId}
                  routeType={route.routeType}
                  name={route.routeShortName}
                  href={`/lines/${route.routeShortName}#alerts`}
                  altBusColors
                  busAlertBadge
                  className="mr-3 mb-4"
                />
              ))
            }
          </div>
        </CardBody>
      </Card>
    </Column>
  </div>
</Layout>
