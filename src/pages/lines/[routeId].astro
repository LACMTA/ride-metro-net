---
import { openDb } from "gtfs";
import Layout from "../../layouts/Layout.astro";
import { GTFSconfig } from "../../integrations/import-gtfs";
import getRouteById from "../../lib/getRouteById";
import Column from "../../components/Column";
import BusPill from "../../components/BusBadge";
import RailIcon from "../../components/RailBadge";
import BusIcon from "../../components/BusIcon";
import { ROUTE_SHORT_NAME_OVERRIDES } from "../../lib/routeShortNameOverrides";
import DataInjector from "../../components/DataInjector.astro";
import LineTabs from "../../components/LineTabs";

export const prerender = true;

export async function getStaticPaths() {
  const db = openDb(GTFSconfig);
  // Build pages for all routes that have trips (are active in the schedule).
  // Strip the version suffix from route_id (e.g. "901-13196" → "901") so that
  // page URLs are stable across GTFS releases, then deduplicate.
  const allRoutes = (await db
    .prepare(
      `
      SELECT DISTINCT r.route_id
      FROM routes r
      JOIN trips t ON t.route_id = r.route_id
      ORDER BY r.route_id
      `,
    )
    .all()) as { route_id: string }[];

  const uniquePrefixes = [
    ...new Set(allRoutes.map((route) => route.route_id.split("-")[0])),
  ];

  return uniquePrefixes.map((numericPrefix) => {
    const letter = ROUTE_SHORT_NAME_OVERRIDES[numericPrefix];
    // Routes with a letter override are served at e.g. /lines/a instead of /lines/801
    const slug = letter ? letter.toLowerCase() : numericPrefix;
    return {
      params: { routeId: slug },
      props: { numericId: numericPrefix },
    };
  });
}

const { routeId } = Astro.params;
const { numericId } = Astro.props as { numericId: string };

// Use the numeric prefix for the DB lookup regardless of whether the URL slug
// is a letter (e.g. "a" → "801") or a plain numeric id (e.g. "720").
const route = await getRouteById(numericId ?? routeId);
---

<DataInjector data={route} id="data-route" />
<script>
  import { getData } from "../../lib/getData";
  import type { RouteWithInfo } from "../../lib/getRouteById";
  import watchAlerts from "../../lib/watchAlerts";

  const route = getData("data-route") as RouteWithInfo;

  watchAlerts(
    [], // no stop IDs for a route page
    [route.routeId],
    route.swiftlyAgencyId,
  );
</script>

<Layout title={`Line ${route.routeShortName}`}>
  <Column>
    <div class="mt-6 mb-4 flex items-center">
      {
        route.routeType === 3 && (
          <BusIcon className="text-metro-text mr-4 h-8 shrink-0" />
        )
      }
      <ul>
        {
          route.routeType !== 3 ? (
            <li class="my-1 mr-1.5 inline-block">
              <RailIcon
                name={route.routeShortName}
                color={route.routeColor}
                textColor={route.routeTextColor}
              />
            </li>
          ) : (
            <li class="my-1 mr-1.5 inline-block">
              <BusPill name={route.routeShortName} />
            </li>
          )
        }
      </ul>
    </div>
  </Column>
  <main>
    <LineTabs routeId={route.routeId} client:load />
  </main>
</Layout>
